{
  "openapi": "3.0.3",
  "info": {
    "title": "LeetCode API",
    "version": "1.0.0",
    "description": "OpenAPI specification for the public endpoints exposed by the Alfa LeetCode API server."
  },
  "servers": [
    {
      "url": "https://leetcode-api-a413.onrender.com",
      "description": "Production server"
    }
  ],
  "tags": [
    {
      "name": "root",
      "description": "Service root and index"
    },
    {
      "name": "userDetails",
      "description": "User profile, stats, submissions, badges, and contests"
    },
    {
      "name": "contest",
      "description": "Contest ranking and history"
    },
    {
      "name": "discussion",
      "description": "Trending discussions, topics and comments"
    },
    {
      "name": "problems",
      "description": "Problem list, selection, daily, and official solutions"
    }
  ],
  "paths": {
    "/": {
      "get": {
        "tags": [
          "root"
        ],
        "summary": "API index",
        "description": "Returns a list of available routes and usage hints.",
        "responses": {
          "200": {
            "description": "Index payload",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    },
    "/officialSolution": {
      "get": {
        "tags": [
          "problems"
        ],
        "summary": "Get official solution for a problem",
        "parameters": [
          {
            "name": "titleSlug",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Problem slug, e.g., two-sum"
          }
        ],
        "responses": {
          "200": {
            "description": "Official solution payload",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Missing titleSlug",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Upstream/Server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/userProfileCalendar": {
      "get": {
        "tags": [
          "userDetails"
        ],
        "summary": "Get user submission calendar for a year",
        "parameters": [
          {
            "name": "username",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "year",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Year, e.g., 2024"
          }
        ],
        "responses": {
          "200": {
            "description": "Calendar payload",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Missing or invalid username/year",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Upstream/Server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
